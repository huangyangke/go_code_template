# 生产环境变量 — 不提交真实值，通过部署系统注入或写在服务器本地
APP_FAMILY=go-template
GIN_MODE=release
LOG_LEVEL=info
LOG_STDOUT=false

MYSQL_DSN=
REDIS_ADDR=
REDIS_PASSWORD=

# CORS（生产改为具体域名，逗号分隔）
CORS_ALLOW_ORIGINS=

# JWT 鉴权
AIKIT_AUTH_ENABLED=false
AIKIT_AUTH_JWT_SECRET_KEY=

# 内部 Token（务必设置随机复杂字符串）
AIKIT_INTERNAL_TOKEN=

# 限流
RATE_LIMIT_ENABLED=false

# 缓存（生产使用 L1+L2 多级缓存）
CACHE_TYPE=both

# 异步队列
ASYNC_QUEUE_ENABLED=false