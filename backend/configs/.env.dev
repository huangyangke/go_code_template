# 服务设置
APP_FAMILY=go-template
GIN_MODE=debug # gin模式
LOG_LEVEL=info
LOG_STDOUT=true

# 数据库：sqlite:///path 或 mysql DSN，aikit 自动识别驱动
DB_DSN=sqlite:///data/app.db
# Redis（本地开发可注释掉，CACHE_TYPE=local 不依赖 Redis）
#REDIS_ADDR=127.0.0.1:6379

# CORS（dev 允许所有来源，生产改为具体域名，逗号分隔）
CORS_ALLOW_ORIGINS=*

# JWT 鉴权（启用后提供 /v1/auth/login、/v1/auth/register、/v1/auth/me）
AIKIT_AUTH_ENABLED=false
AIKIT_AUTH_JWT_SECRET_KEY=dev-secret-change-me

# 内部 Token（跨服务互调用，留空不启用）
AIKIT_INTERNAL_TOKEN=

# 限流（默认关闭）
RATE_LIMIT_ENABLED=false

# 缓存（dev 使用本地缓存，不依赖 Redis）
CACHE_TYPE=local

# 异步队列（默认关闭，启用需配置 Redis）
ASYNC_QUEUE_ENABLED=false